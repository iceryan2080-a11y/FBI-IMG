# Umbral de confianza YOLO.
# Metodología del proyecto: 0.75 con el modelo entrenado (best.pt).
# Mientras uses el modelo base COCO (sin entrenar), 0.35 da resultados visibles.
CONF_THRESHOLD=0.35

# Modo completo: diccionario rockyou (contraseñas filtradas).
# ROCKYOU_HOST: ruta en el host montada en el backend como /dicts/rockyou.txt
# ROCKYOU_FRACTION: fracción del archivo a cargar (0.5 = la mitad más común)
ROCKYOU_HOST=/home/asti20/Desktop/DICCIONARIOS/rockyou.txt
ROCKYOU_FRACTION=0.5
